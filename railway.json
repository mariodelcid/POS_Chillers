{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_20"]
        },
        "install": {
          "cmds": ["npm ci"]
        },
        "build": {
          "cmds": ["npm run build"]
        },
        "start": {
          "cmd": "npm start"
        }
      }
    }
  },
  "deploy": {
    "preDeployCommand": "npx prisma db push --accept-data-loss"
  }
}


